---
import RawLayout from "./RawLayout.astro";
import Footer from "../components/Footer.astro";
import "../styles/site.scss";
import {withBase} from "../utils/withBase";

const {
    title = "23rd Special Tactics Squadron",
    activePage = "",
    headerText = "23rd STS",
    showNav = true,
} = Astro.props;
---

<RawLayout {title}>
<!--
    <Fragment slot="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,-25" rel="stylesheet"/>
    </Fragment>
-->
    <header>
        <div class="logo">
            <a href={withBase()} aria-label="Go to homepage">
                <img src={withBase("assets/logo.png")} alt="23rd STS Logo"/>
            </a>
            <span class="logo-text">{headerText}</span>
        </div>
        {showNav && (
                <nav>
                    <ul>
                        <li><a class={activePage === "home" ? "is-active" : undefined} href={withBase()}> HOME </a></li>
                        <li><a class={activePage === "apply" ? "is-active" : undefined} href={withBase("apply/")}> APPLY </a></li>
                        <li><a class={activePage === "discord" ? "is-active" : undefined} href={withBase("discord/")}> DISCORD </a></li>
                    </ul>
                </nav>
        )}
    </header>
    <main>
        <slot/>
    </main>
    <Footer/>
</RawLayout>
