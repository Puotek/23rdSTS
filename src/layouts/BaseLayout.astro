---
import "../styles/site.css";

const {title = "23rd Special Tactics Squadron", activePage = ""} = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path = "") => `${base.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="generator" content={Astro.generator}/>
    <link rel="icon" href={withBase("favicon.ico")}/>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
          rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,-25"
          rel="stylesheet"/>
</head>
<body>
<header>
    <div class="logo">
        <a href={withBase()} aria-label="Go to homepage">
            <img src={withBase("assets/logo.png")} alt="23rd STS Logo"/>
        </a>
        <span class="logo-text">23rd STS</span>
    </div>
    <nav>
        <ul>
            <li><a class={activePage === "home" ? "is-active" : undefined} href={withBase()}> HOME </a></li>
            <li><a class={activePage === "apply" ? "is-active" : undefined} href={withBase("apply/")}> APPLY </a></li>
            <li><a class={activePage === "discord" ? "is-active" : undefined} href={withBase("discord/")}> DISCORD </a>
            </li>
        </ul>
    </nav>
</header>

<main>
    <slot/>
</main>

<footer class="footer">
    © 2023-2026 // 23rd Special Tactics Squadron
</footer>
</body>
</html>
