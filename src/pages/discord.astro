---
import RawLayout from "../layouts/RawLayout.astro";
const inviteUrl = "https://discord.gg/YrHST8EcfC";
---

<RawLayout title="23rd STS Discord">
    <Fragment slot="head">
        <script is:inline>
            window.location.replace("https://discord.gg/YrHST8EcfC");
        </script>
        <noscript>
            <meta http-equiv="refresh" content={`0;url=${inviteUrl}`}/>
        </noscript>
    </Fragment>
</RawLayout>
