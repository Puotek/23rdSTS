---
import {withBase} from "../utils/withBase.ts";
const home = withBase("");
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta http-equiv="refresh" content={`0; url=${home}`}/>
    <link rel="canonical" href={home}/>
    <title>Redirecting…</title>
</head>
<body>
<script set:html={`window.location.replace(${JSON.stringify(home)});`}></script>
<p>Redirecting to <a href={home}>{home}</a>…</p>
</body>
</html>
