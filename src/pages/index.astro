---
const newSite = "https://23rdsts.pages.dev";
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="robots" content="noindex"/>
    <link rel="canonical" href={newSite}/>
    <title>23rd STS — Site Retired</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            background: #0b0b0c;
            color: #e8e8ea;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            box-sizing: border-box;
            text-align: center;
        }
        main {
            max-width: 36rem;
        }
        h1 {
            font-size: 1.5rem;
            font-weight: 600;
            margin: 0 0 1rem;
            letter-spacing: 0.02em;
        }
        p {
            font-size: 1.05rem;
            line-height: 1.5;
            margin: 0 0 1.5rem;
            color: #c7c7cc;
        }
        a {
            color: #fff;
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
            transition: border-color 0.15s ease;
        }
        a:hover {
            border-bottom-color: #fff;
        }
    </style>
</head>
<body>
<main>
    <h1>This URL has been retired</h1>
    <p>
        We have moved to <a href={newSite}>23rdsts.pages.dev</a>.
    </p>
</main>
</body>
</html>
